{
  "display": "Node LTS",
  "_version": "18.1.0",
  "compilerOptions": {
    "lib": [
      "es2024"
    ],
    "rootDir": "src",
    "outDir": "dist",  // this will emit all the typrscript that you are trying to pull and put in the dist directory
    "module": "node16",
    "target": "es2024",
    "strict": true,
    "noUncheckedIndexedAccess": true,  // Extra rule for protection
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "moduleResolution": "node16",
    "types": ["node"]
  },
  "include": [
    "src"
  ],
  "exclude": [
    "src/**/*.test.ts",
    "src/__tests__"
  ]
}
